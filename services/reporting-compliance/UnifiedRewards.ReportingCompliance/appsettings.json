{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "urp-employee-profile",
    "Audience": "urp",
    "RsaPublicKey": "<RSAKeyValue><Modulus></Modulus><Exponent>AQAB</Exponent></RSAKeyValue>"
  },
  "Services": {
    "Reimbursement": "http://localhost:5104",
    "Payroll": "http://localhost:5106"
  },
  "Messaging": {
    "Provider": "Local"
  },
  "Retention": {
    "YearsToKeep": 7
  }
}
