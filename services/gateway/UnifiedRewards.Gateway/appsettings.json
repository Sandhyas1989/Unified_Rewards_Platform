{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://localhost:3002",
      "http://localhost:3003",
      "http://localhost:3004"
    ]
  },
  "RateLimit": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "ReverseProxy": {
    "Routes": {
      "auth":                  { "ClusterId": "employee-profile",      "Match": { "Path": "/api/auth/{**catch-all}" } },
      "employee-profile":      { "ClusterId": "employee-profile",      "Match": { "Path": "/api/employees/{**catch-all}" } },
      "promotions":            { "ClusterId": "employee-profile",      "Match": { "Path": "/api/promotions/{**catch-all}" } },
      "benefits-catalogue":    { "ClusterId": "benefits-catalogue",    "Match": { "Path": "/api/benefit-plans/{**catch-all}" } },
      "benefits-enrollments":  { "ClusterId": "benefits-catalogue",    "Match": { "Path": "/api/enrollments/{**catch-all}" } },
      "compensation-rules":    { "ClusterId": "compensation-rules",    "Match": { "Path": "/api/compensation/{**catch-all}" } },
      "reimbursement-workflow":{ "ClusterId": "reimbursement-workflow","Match": { "Path": "/api/claims/{**catch-all}" } },
      "document-processing":   { "ClusterId": "document-processing",   "Match": { "Path": "/api/documents/{**catch-all}" } },
      "payroll-integration":   { "ClusterId": "payroll-integration",   "Match": { "Path": "/api/settlements/{**catch-all}" } },
      "payroll-payslips":      { "ClusterId": "payroll-integration",   "Match": { "Path": "/api/payslips/{**catch-all}" } },
      "reporting-compliance":  { "ClusterId": "reporting-compliance",  "Match": { "Path": "/api/reports/{**catch-all}" } },
      "reporting-audit":       { "ClusterId": "reporting-compliance",  "Match": { "Path": "/api/audit/{**catch-all}" } }
    },
    "Clusters": {
      "employee-profile":      { "Destinations": { "primary": { "Address": "http://localhost:5101/" } } },
      "benefits-catalogue":    { "Destinations": { "primary": { "Address": "http://localhost:5102/" } } },
      "compensation-rules":    { "Destinations": { "primary": { "Address": "http://localhost:5103/" } } },
      "reimbursement-workflow":{ "Destinations": { "primary": { "Address": "http://localhost:5104/" } } },
      "document-processing":   { "Destinations": { "primary": { "Address": "http://localhost:5105/" } } },
      "payroll-integration":   { "Destinations": { "primary": { "Address": "http://localhost:5106/" } } },
      "reporting-compliance":  { "Destinations": { "primary": { "Address": "http://localhost:5107/" } } }
    }
  }
}
